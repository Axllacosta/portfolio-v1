---
import type { Project } from '../types/project';

interface Props extends Project {}

const {
    id,
    title,
    subtitle,
    longDescription,
    architecture,
    features,
    businessRules,
    technicalHighlights,
    repoUrl,
    demoUrl,
    apiDocsUrl,
} = Astro.props;
---

<div
        id={`${id}-modal`}
        data-modal
        class="fixed inset-0 z-50 hidden items-center justify-center p-6"
        role="dialog"
        aria-modal="true"
        aria-labelledby={`${id}-modal-title`}
>
    <div class="focus-overlay" data-overlay></div>

    <div
            class="relative z-50 max-h-[90vh] w-full max-w-2xl overflow-y-auto rounded-2xl bg-white p-8 shadow-2xl"
            data-modal-content
            tabindex="-1"
    >
        <div class="flex items-start justify-between gap-4 mb-8">
            <div>
                <h2 id={`${id}-modal-title`} class="text-2xl font-semibold text-slate-900">{title}</h2>
                {subtitle && <p class="mt-1 text-sm text-slate-500">{subtitle}</p>}
            </div>
            <button type="button" data-close-modal class="cursor-pointer rounded-full p-2 text-slate-400 transition hover:bg-slate-100 hover:text-slate-600" aria-label="Close modal">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
        </div>

        <div class="flex flex-wrap gap-3 mb-8">
            {repoUrl && (
                    <a href={repoUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white transition hover:bg-slate-800">
                        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                        <span data-i18n="modal.viewRepository">View Repository</span>
                    </a>
            )}
            {demoUrl && (
                    <a href={demoUrl === '#' ? '#' : demoUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-slate-400 hover:bg-slate-50">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                        <span data-i18n="modal.liveDemo">Live Demo</span>
                        {demoUrl === '#' && <span class="text-xs text-slate-400" data-i18n="modal.comingSoon">(Coming Soon)</span>}
                    </a>
            )}
        </div>

        <section class="mb-8">
            <h3 class="font-semibold text-slate-900 mb-3" data-i18n="modal.overview">Overview</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{longDescription}</p>
        </section>

        <div class="h-px w-full bg-slate-200 my-6"></div>

        <section class="mb-8">
            <h3 class="font-semibold text-slate-900 mb-3" data-i18n="modal.architecture">Architecture</h3>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                {architecture.map((item) => (<li class="flex items-center gap-2 text-sm text-slate-600"><span class="h-1.5 w-1.5 rounded-full bg-teal-600 shrink-0"></span>{item}</li>))}
            </ul>
        </section>

        <div class="h-px w-full bg-slate-200 my-6"></div>

        <section class="mb-8">
            <h3 class="font-semibold text-slate-900 mb-3" data-i18n="modal.coreFeatures">Core Features</h3>
            <ul class="space-y-2">
                {features.map((feature) => (<li class="flex items-center gap-2 text-sm text-slate-600"><span class="h-1.5 w-1.5 rounded-full bg-slate-400 shrink-0"></span>{feature}</li>))}
            </ul>
        </section>

        <div class="h-px w-full bg-slate-200 my-6"></div>

        <section class="mb-8">
            <h3 class="font-semibold text-slate-900 mb-3" data-i18n="modal.businessRules">Business Rules</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                {businessRules.map((rule) => (<div class="flex items-start gap-2 text-sm text-slate-600"><span class="mt-1 h-1.5 w-1.5 rounded-full bg-teal-600 shrink-0"></span>{rule}</div>))}
            </div>
        </section>

        <div class="h-px w-full bg-slate-200 my-6"></div>

        <section class="mb-8">
            <h3 class="font-semibold text-slate-900 mb-3" data-i18n="modal.technicalHighlights">Technical Highlights</h3>
            <ul class="space-y-2">
                {technicalHighlights.map((highlight) => (<li class="flex items-center gap-2 text-sm text-slate-600"><span class="h-1.5 w-1.5 rounded-full bg-slate-400 shrink-0"></span>{highlight}</li>))}
            </ul>
        </section>

        <div class="h-px w-full bg-slate-200 my-6"></div>

        <section>
            <h3 class="font-semibold text-slate-900 mb-3" data-i18n="modal.links">Links</h3>
            <div class="space-y-2">
                {repoUrl && (<a href={repoUrl} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-teal-700 hover:text-teal-600 transition"><span data-i18n="modal.repository">Repository</span><svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg></a>)}
                {demoUrl && (<a href={demoUrl === '#' ? '#' : demoUrl} class="flex items-center gap-2 text-sm text-slate-500"><span data-i18n="modal.liveDemo">Live Demo</span>{demoUrl === '#' && <span class="text-xs text-slate-400" data-i18n="modal.comingSoon">(Coming Soon)</span>}</a>)}
                {apiDocsUrl && (<a href={apiDocsUrl === '#' ? '#' : apiDocsUrl} class="flex items-center gap-2 text-sm text-slate-500"><span data-i18n="modal.apiDocs">API Docs</span>{apiDocsUrl === '#' && <span class="text-xs text-slate-400" data-i18n="modal.comingSoon">(Coming Soon)</span>}</a>)}
            </div>
        </section>
    </div>
</div>