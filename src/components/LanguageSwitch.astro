---
export interface Props {
    lang?: string;
}

const { lang = 'en' } = Astro.props;
---

<button
        type="button"
        class="lang-switch group relative flex items-center rounded-full border border-slate-200 bg-slate-50 p-0.5 shadow-sm"
        aria-label="Switch language"
>
    <span class="relative z-10 flex items-center justify-center rounded-full px-3 py-1.5 text-xs font-semibold text-white bg-slate-900">
        EN
    </span>
    <span class="relative z-10 flex items-center justify-center rounded-full px-3 py-1.5 text-xs font-semibold text-slate-400">
        ES
    </span>
</button>