---

---
<section id="skills" class="mb-16 scroll-mt-16 md:mb-24 lg:mb-36 lg:scroll-mt-24">
    <div class="mb-6">
        <h2 class="section-anchor text-md font-bold uppercase tracking-widest text-slate-900" data-i18n="skills.title">Skills</h2>
        <div class="mt-3 h-px w-full bg-slate-400"></div>
    </div>
    <div class="space-y-8">
        <div class="grid gap-8 md:grid-cols-3">
            <div class="border-b border-slate-200 pb-8 md:border-b-0 md:border-r md:pr-8">
                <div class="mb-4 flex items-center gap-2">
                    <svg class="h-5 w-5 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
                    <h3 class="font-semibold text-slate-900" data-i18n="skills.languages">Languages</h3>
                </div>
                <div class="flex flex-wrap items-center gap-6">
                    <div class="flex flex-col items-center gap-2"><img src="/public/icons/python.svg" alt="Python" class="h-12 w-12" /><span class="text-xs text-slate-600">Python</span></div>
                    <div class="flex flex-col items-center gap-2"><img src="/public/icons/java.svg" alt="Java" class="h-12 w-12" /><span class="text-xs text-slate-600">Java</span></div>
                    <div class="flex flex-col items-center gap-2"><img src="/public/icons/typescript.svg" alt="TypeScript" class="h-12 w-12" /><span class="text-xs text-slate-600">TypeScript</span></div>
                </div>
            </div>
            <div class="border-b border-slate-200 pb-8 md:border-b-0 md:border-r md:pr-8">
                <div class="mb-4 flex items-center gap-2">
                    <svg class="h-5 w-5 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"/></svg>
                    <h3 class="font-semibold text-slate-900" data-i18n="skills.backend">Backend</h3>
                </div>
                <div class="flex flex-wrap items-center gap-6">
                    <div class="flex flex-col items-center gap-2"><img src="/public/icons/fastapi.svg" alt="FastAPI" class="h-12 w-12" /><span class="text-xs text-slate-600">FastAPI</span></div>
                    <div class="flex flex-col items-center gap-2"><img src="/public/icons/django.svg" alt="Django" class="h-12 w-12" /><span class="text-xs text-slate-600">Django</span></div>
                </div>
            </div>
            <div class="border-b border-slate-200 pb-8 md:border-b-0">
                <div class="mb-4 flex items-center gap-2">
                    <svg class="h-5 w-5 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"/></svg>
                    <h3 class="font-semibold text-slate-900" data-i18n="skills.databases">Databases</h3>
                </div>
                <div class="flex flex-wrap items-center gap-6">
                    <div class="flex flex-col items-center gap-2"><img src="/public/icons/PostgresSQL.svg" alt="PostgreSQL" class="h-12 w-12" /><span class="text-xs text-slate-600">PostgreSQL</span></div>
                    <div class="flex flex-col items-center gap-2"><img src="/public/icons/mysql.svg" alt="MySQL" class="h-12 w-12" /><span class="text-xs text-slate-600">MySQL</span></div>
                </div>
            </div>
        </div>
        <div class="h-px w-full bg-slate-200"></div>
        <div class="grid gap-8 md:grid-cols-[1fr_1.5fr]">
            <div class="flex flex-col items-center border-b border-slate-200 pb-8 md:border-b-0 md:border-r md:pr-8">
                <div class="mb-6 flex items-center gap-2 self-start">
                    <svg class="h-5 w-5 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/></svg>
                    <h3 class="font-semibold text-slate-900" data-i18n="skills.tools">Tools</h3>
                </div>
                <div class="flex w-full flex-wrap justify-center gap-6">
                    <div class="flex flex-col items-center gap-2"><img src="/public/icons/git.svg" alt="Git" class="h-12 w-12" /><span class="text-xs text-slate-600">Git</span></div>
                    <div class="flex flex-col items-center gap-2"><img src="/public/icons/postman.svg" alt="Postman" class="h-12 w-12" /><span class="text-xs text-slate-600">Postman</span></div>
                    <div class="flex flex-col items-center gap-2"><img src="/public/icons/github.svg" alt="GitHub" class="h-12 w-12" /><span class="text-xs text-slate-600">GitHub</span></div>
                    <div class="flex flex-col items-center gap-2"><img src="/public/icons/gitlab.svg" alt="GitLab" class="h-12 w-12" /><span class="text-xs text-slate-600">GitLab</span></div>
                </div>
            </div>
            <div class="flex flex-col items-center md:pl-8">
                <div class="mb-6 flex items-center gap-2 self-start">
                    <svg class="h-5 w-5 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                    <h3 class="font-semibold text-slate-900" data-i18n="skills.frontend">Frontend</h3>
                </div>
                <div class="flex w-full flex-wrap justify-center gap-8">
                    <div class="flex flex-col items-center gap-2"><img src="/public/icons/astro.svg" alt="Astro" class="h-14 w-14" /><span class="text-xs text-slate-600">Astro</span></div>
                    <div class="flex flex-col items-center gap-2"><img src="/public/icons/angular.svg" alt="Angular" class="h-14 w-14" /><span class="text-xs text-slate-600">Angular</span></div>
                    <div class="flex flex-col items-center gap-2"><img src="/public/icons/sass.svg" alt="Sass" class="h-14 w-14" /><span class="text-xs text-slate-600">Sass</span></div>
                    <div class="flex flex-col items-center gap-2"><img src="/public/icons/css3.svg" alt="CSS" class="h-14 w-14" /><span class="text-xs text-slate-600">CSS</span></div>
                    <div class="flex flex-col items-center gap-2"><img src="/public/icons/html5.svg" alt="HTML" class="h-14 w-14" /><span class="text-xs text-slate-600">HTML</span></div>
                </div>
            </div>
        </div>
    </div>
</section>