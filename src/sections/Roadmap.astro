<section id="roadmap" class="mb-16 scroll-mt-16 md:mb-24 lg:mb-36 lg:scroll-mt-24">
    <div class="mb-6">
        <h2 class="section-anchor text-md font-bold uppercase tracking-widest text-slate-900" data-i18n="roadmap.title">Roadmap 2026</h2>
        <div class="mt-3 h-px w-full bg-slate-400"></div>
    </div>
    <div>
        <ul class="relative space-y-8 before:absolute before:left-[7px] before:top-2 before:h-[calc(100%-2rem)] before:w-px before:bg-slate-300">
            <li class="relative flex items-start gap-4 pl-8">
                <div class="absolute left-0 top-1 h-4 w-4 rounded-full border-2 border-teal-600 bg-white"></div>
                <div class="flex-1">
                    <h3 class="font-semibold text-slate-900" data-i18n="roadmap.phases.0.title">Phase 1 — Backend Development (Current Focus)</h3>
                    <p class="mt-1 text-sm text-slate-600" data-i18n="roadmap.phases.0.description">Deepening backend fundamentals through APIs, authentication, database design, and scalable application development.</p>
                    <span class="mt-2 inline-block text-xs font-medium text-teal-600" data-i18n="roadmap.phases.0.status">In Progress</span>
                </div>
            </li>
            <li class="relative flex items-start gap-4 pl-8">
                <div class="absolute left-0 top-1 h-4 w-4 rounded-full border-2 border-slate-400 bg-white"></div>
                <div class="flex-1">
                    <h3 class="font-semibold text-slate-900" data-i18n="roadmap.phases.1.title">Phase 2 — Software Architecture</h3>
                    <p class="mt-1 text-sm text-slate-600" data-i18n="roadmap.phases.1.description">Deepening knowledge in modular monoliths, hexagonal architecture, clean architecture, and system design principles.</p>
                    <span class="mt-2 inline-block text-xs font-medium text-slate-500" data-i18n="roadmap.phases.1.status">Next Step</span>
                </div>
            </li>
            <li class="relative flex items-start gap-4 pl-8">
                <div class="absolute left-0 top-1 h-4 w-4 rounded-full border-2 border-slate-400 bg-white"></div>
                <div class="flex-1">
                    <h3 class="font-semibold text-slate-900" data-i18n="roadmap.phases.2.title">Phase 3 — DevOps & Infrastructure</h3>
                    <p class="mt-1 text-sm text-slate-600" data-i18n="roadmap.phases.2.description">Learning containerization, CI/CD pipelines, deployment workflows, Linux environments, and production-ready practices.</p>
                    <span class="mt-2 inline-block text-xs font-medium text-slate-500" data-i18n="roadmap.phases.2.status">Planned</span>
                </div>
            </li>
            <li class="relative flex items-start gap-4 pl-8">
                <div class="absolute left-0 top-1 h-4 w-4 rounded-full border-2 border-slate-400 bg-white"></div>
                <div class="flex-1">
                    <h3 class="font-semibold text-slate-900" data-i18n="roadmap.phases.3.title">Phase 4 — Cloud & AI Systems</h3>
                    <p class="mt-1 text-sm text-slate-600" data-i18n="roadmap.phases.3.description">Expanding into cloud infrastructure, scalable deployments, and AI-powered systems for real-world applications.</p>
                    <span class="mt-2 inline-block text-xs font-medium text-slate-500" data-i18n="roadmap.phases.3.status">Long-Term Goal</span>
                </div>
            </li>
        </ul>
    </div>
</section>