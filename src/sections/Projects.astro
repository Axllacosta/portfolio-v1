---
import ProjectModal from '../components/ProjectModal.astro';
import { projects } from '../data/project';
---
<section id="projects" class="mb-16 scroll-mt-16 md:mb-24 lg:mb-36 lg:scroll-mt-24">
    <div class="mb-6">
        <h2 class="section-anchor text-md font-bold uppercase tracking-widest text-slate-900" data-i18n="projects.title">Projects</h2>
        <div class="mt-3 h-px w-full bg-slate-400"></div>
    </div>

    {projects.length === 0 ? (
            <div class="flex flex-col items-center justify-center py-16 text-center">
                <svg class="h-12 w-12 text-slate-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
                </svg>
                <p class="text-slate-500 text-lg font-medium" data-i18n="projects.comingSoon">Projects Coming Soon</p>
                <p class="mt-2 max-w-md text-slate-400 text-sm leading-relaxed" data-i18n="projects.comingSoonDescription">
                    Currently building and refining projects to showcase here. Check back soon or visit my GitHub for what I'm working on right now.
                </p>
                <a href="https://github.com/Axllacosta" target="_blank" rel="noreferrer"
                   class="mt-6 inline-flex items-center gap-2 rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white transition hover:bg-slate-800">
                    <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                    <span data-i18n="projects.viewGitHub">View GitHub</span>
                </a>
            </div>
    ) : (
            <div>
                <ul class="group/list space-y-8">
                    {projects.map((project) => (
                            <li class="group relative">
                                <button type="button" data-project={project.id} aria-label={`Open ${project.title} details`}
                                        class="relative grid w-full cursor-pointer gap-4 pb-1 text-left transition-all sm:grid-cols-8 sm:gap-8 md:gap-4 lg:hover:!opacity-100 lg:group-hover/list:opacity-50 focus:outline-none">
                                    <div class="absolute -inset-x-4 -inset-y-4 z-0 hidden rounded-md transition motion-reduce:transition-none lg:-inset-x-6 lg:block lg:group-hover:bg-slate-50 lg:group-hover:shadow-[inset_0_1px_0_0_rgba(148,163,184,0.1)] lg:group-hover:drop-shadow-lg"></div>
                                    <div class="relative z-10 sm:order-2 sm:col-span-6">
                                        <h3 class="inline-flex items-baseline font-medium leading-tight text-slate-900 transition-colors group-hover:text-teal-700 group-focus-visible:text-teal-700 text-base">
                                            <span>{project.title}</span>
                                        </h3>
                                        <p class="mt-2 text-sm leading-normal text-slate-600">{project.description}</p>
                                        <ul class="mt-3 flex flex-wrap gap-2" aria-label="Technologies used">
                                            {project.technologies.map((tech) => (
                                                    <li><span class="inline-flex items-center rounded-full bg-teal-400/10 px-3 py-1 text-xs font-medium leading-5 text-teal-700">{tech}</span></li>
                                            ))}
                                        </ul>
                                    </div>
                                </button>
                            </li>
                    ))}
                </ul>
            </div>
    )}
</section>

{projects.map((project) => (
<ProjectModal {...project} />
    ))}

<script>
    import '../scripts/modal.ts';
</script>