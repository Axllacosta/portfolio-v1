                                <rect x="0" y="0" width="24" height="24" rx="5" ry="5" />
                                <circle cx="6.3" cy="8" r="1.5" fill="white" />
                                <rect x="5.2" y="10" width="2.2" height="8" fill="white" />
                                <path fill="white" d="M10 10h2.1v1.2h.03c.3-.57 1.13-1.35 2.55-1.35 2.72 0 3.22 1.8 3.22 4.13V18h-2.3v-3.5c0-.83-.02-1.92-1.18-1.92-1.18 0-1.36.92-1.36 1.86V18H10z" />
                            </svg>
                        </a>
                    </li>
                    <li class="text-xs">
                        <a class="block text-slate-900 hover:text-slate-600 transition" href="mailto:axlacostab@gmail.com" target="_blank" rel="noreferrer">
                            <span class="sr-only">Email</span>
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-7 w-7" aria-hidden="true">
                                <path d="M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z"></path>
                                <path d="M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z"></path>
                            </svg>
