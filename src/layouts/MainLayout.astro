                                <span class="nav-text text-sm font-bold uppercase tracking-widest text-slate-900 group-hover:text-slate-900 group-focus-visible:text-slate-900" data-i18n="nav.essentials">Essentials</span>
                            </a>
                        </li>
                        <li>
                            <a class="group flex items-center py-3" href="#skills">
                                <span class="nav-indicator mr-4 h-px w-8 bg-slate-900 transition-all duration-300 ease-out group-hover:w-16 group-hover:bg-slate-900 group-focus-visible:w-16 group-focus-visible:bg-slate-900 motion-reduce:transition-none"></span>
                                <span class="nav-text text-sm font-bold uppercase tracking-widest text-slate-900 group-hover:text-slate-900 group-focus-visible:text-slate-900" data-i18n="nav.skills">Skills</span>
