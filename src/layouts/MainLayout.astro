---
import '../styles/global.css';
import LanguageSwitch from '../components/LanguageSwitch.astro';

export interface Props {
    title?: string;
    description?: string;
    lang?: string;
}

const {
    title = "Axel Acosta | Portfolio",
    description = "Backend Developer Portfolio",
    lang = 'en'
} = Astro.props;
---

<html lang={lang}>
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/lgv1.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@200;300;400;500;600;700&display=swap" rel="stylesheet">
</head>

<body class="bg-white text-slate-900 overflow-hidden">

<!-- Language Switch -->
<div class="fixed top-6 left-6 z-30">
    <LanguageSwitch lang={lang} />
</div>

<div class="mx-auto w-full max-w-[1600px] h-screen px-6 md:px-8 lg:px-8">
