                            </a>
                        </li>
                        <li>
                            <a class="group flex items-center py-3" href="#learning">
                                <span class="nav-indicator mr-4 h-px w-8 bg-slate-900 transition-all group-hover:w-16 group-hover:bg-slate-900 group-focus-visible:w-16 group-focus-visible:bg-slate-900 motion-reduce:transition-none"></span>
