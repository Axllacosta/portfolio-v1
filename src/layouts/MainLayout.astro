            </div>
        </header>

        <div class="hidden lg:block w-px bg-slate-600 mx-6 my-16 shrink-0"></div>

        <main id="content" class="lg:flex-1 lg:min-w-0 lg:overflow-y-auto lg:overflow-x-hidden lg:px-12 lg:py-24">
            <slot />
        </main>
    </div>
</div>
</body>
</html>

//Nav animation
<script>
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function(e) {
            e.preventDefault();
            const container = document.querySelector('#content');
            const target = document.querySelector(this.getAttribute('href'));
            if (target && container) {
                container.scrollTo({ top: target.offsetTop - 96, behavior: 'smooth' });
            }
        });
    });

    const mainContent = document.querySelector('#content');
    const sections = document.querySelectorAll('.section-anchor');
    const ACTIVE = { indicator: ['bg-slate-900', 'w-16'], text: 'text-slate-900' };
    const INACTIVE_OBSERVER = { indicator: ['bg-slate-500', 'w-8'], text: 'text-slate-500' };
    const INACTIVE_CONTACT = { indicator: ['bg-slate-300', 'w-8'], text: 'text-slate-400' };

    function activateNavLink(activeId, inactiveStyle) {
        document.querySelectorAll('.nav a').forEach(link => {
            const indicator = link.querySelector('.nav-indicator');
            const text = link.querySelector('.nav-text');
            const isActive = link.getAttribute('href') === `#${activeId}`;

            indicator?.classList.remove(...(isActive ? inactiveStyle.indicator : ACTIVE.indicator));
            indicator?.classList.add(...(isActive ? ACTIVE.indicator : inactiveStyle.indicator));
            text?.classList.remove(isActive ? inactiveStyle.text : ACTIVE.text);
            text?.classList.add(isActive ? ACTIVE.text : inactiveStyle.text);
        });
    }

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const id = entry.target.closest('section')?.getAttribute('id');
                if (id) activateNavLink(id, INACTIVE_OBSERVER);
            }
        });
    }, { root: mainContent, rootMargin: '-10% 0px -60% 0px', threshold: 0 });

    sections.forEach(s => observer.observe(s));

    mainContent?.addEventListener('scroll', () => {
        if (mainContent.scrollTop + mainContent.clientHeight >= mainContent.scrollHeight - 10) {
            activateNavLink('contact', INACTIVE_CONTACT);
        }
    });
</script>